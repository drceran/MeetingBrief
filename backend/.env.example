DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/meetingbrief
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
UPLOAD_WEBHOOK_SECRET=your-upload-webhook-secret
CREATE_TABLES=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MEDIA_DIR=backend/media
MEDIA_BASE_URL=
DEV_AUTH_USER_ID=
DEV_AUTH_EMAIL=dev@meetingbrief.local# Copy to .env and fill values
# PostgreSQL DATABASE_URL in SQLAlchemy asyncpg format
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/meetingbrief

# Optional Supabase connection info (useful for other services)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-key
SUPABASE_PUBLISHABLE_KEY=sb_publishable_X5GnwkE46sFJxsHbQev8sQ_qSV4V_qi

# Supabase JWT secret — found at:
# Supabase Dashboard -> Project Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Optional shared secret for upload webhook endpoint
# If set, clients/webhooks must include header: X-Webhook-Secret: <value>
UPLOAD_WEBHOOK_SECRET=your-upload-webhook-secret

# If true, the app will attempt to create tables on startup (development only)
CREATE_TABLES=true

# If true, the backend skips JWT validation and uses a local developer user.
# Recommended for local-only development.
AUTH_DISABLED=true

# Optional local developer identity used when auth is disabled or when dev auth fallback is enabled.
DEV_AUTH_USER_ID=local-dev-user
DEV_AUTH_EMAIL=dev@meetingbrief.local
